# ==========================================================
# Environment Variables — Robinhood Chain Token Launch
# ==========================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control!

# Mainnet (Chain ID 4663)
RH_RPC_URL=https://rpc.mainnet.chain.robinhood.com

# Deployer wallet private key
DEPLOYER_PRIVATE_KEY=0x...

# Treasury wallet address (receives USDG from mints)
TREASURY_ADDRESS=0x...

# Token metadata
TOKEN_NAME="THE VLAD TENEV BULL"
TOKEN_SYMBOL=TVT

# USDG on Robinhood Chain Mainnet
USDG_ADDRESS=0x5fc5360D0400a0Fd4f2af552ADD042D716F1d168
USDC_ADDRESS=0x5fc5360D0400a0Fd4f2af552ADD042D716F1d168

# Uniswap V2 Router on Robinhood Chain Mainnet
UNISWAP_V2_ROUTER=0x8bceaa40b9acdfaedf85adf4ff01f5ad6517937f

# Blockscout API (mainnet)
BLOCKSCOUT_API_URL=https://api.blockscout.com/1/api/v2
BLOCKSCOUT_API_KEY=your_api_key_here
